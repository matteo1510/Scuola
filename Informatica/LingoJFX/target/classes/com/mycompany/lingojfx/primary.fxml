<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.lingojfx.PrimaryController">

    <Label text="Benvenuto in Lingo!" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <Label fx:id="messageLabel" text="Caricamento..." />
    
    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="tentativoField" promptText="Inserisci parola" />
        <Button fx:id="inviaButton" text="Invia" onAction="#handleInvia" />
    </HBox>
    
    <Label fx:id="strikeLabel" text="Strike: " style="-fx-font-size: 14px;"/>
    <Label fx:id="ballLabel" text="Ball:   " style="-fx-font-size: 14px;"/>
    
</VBox>
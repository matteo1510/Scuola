<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="320" prefWidth="620" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.indovinanumero.PrimaryController">

    <children>

        <!-- Titolo -->
        <Label fx:id="title" layoutX="30" layoutY="20" stylesheets="@style.css" text="INDOVINA IL NUMERO (1 - 100)" />

        <!-- Input -->
        <TextField fx:id="inputNumero" layoutX="100" layoutY="80" prefWidth="120" />

        <Button fx:id="btnInvia" layoutX="125" layoutY="130" onAction="#controllaNumero" text="Invia" />

        <!-- Messaggio -->
        <Label id="messaggio" fx:id="labelMessaggio" alignment="CENTER" layoutX="15.0" layoutY="189.0" prefHeight="23.0" prefWidth="287.0" wrapText="true" />

        <!-- Tentativi -->
        <Label id="tentativi" fx:id="labelTentativi" layoutX="90" layoutY="240" prefWidth="200" />

        <!-- Pannello cronologia -->
        <Label layoutX="395.0" layoutY="70.0" style="-fx-text-fill: #38bdf8; -fx-font-size: 16px;" stylesheets="@style.css" text="Cronologia tentativi" textFill="#38bdf8" />

        <ListView fx:id="listaCronologia" layoutX="340" layoutY="112.0" prefHeight="178.0" prefWidth="250" />

    </children>
</AnchorPane>

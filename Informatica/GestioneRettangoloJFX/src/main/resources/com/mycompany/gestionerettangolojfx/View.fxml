<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" 
      prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" 
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.gestionerettangolojfx.ViewController">

    <children>
        <Pane prefHeight="200.0" prefWidth="200.0">
            <children>
                <Label fx:id="lblCorto" layoutX="375.0" layoutY="36.0" prefHeight="61.0" prefWidth="111.0" style="-fx-border-color: red;" />
                <TextField fx:id="txtLatolungo" layoutX="125.0" layoutY="42.0" prefHeight="25.0" prefWidth="89.0" />
                <TextField fx:id="txtLatocorto" layoutX="125.0" layoutY="84.0" prefHeight="25.0" prefWidth="89.0" />
                <Label layoutX="53.0" layoutY="46.0" text="Lato Lungo" />
                <Label layoutX="53.0" layoutY="88.0" text="Lato Corto" />
                <Label fx:id="lblLungo" layoutX="417.0" layoutY="100.0" text="Lungo" />
            </children>
        </Pane>

        <HBox alignment="BASELINE_RIGHT" prefHeight="111.0" prefWidth="600.0" spacing="10">
            <children>
                <Button fx:id="btnCalcola" mnemonicParsing="false" text="Calcola" onAction="#calcola"/>
                <Button fx:id="btnCancella" mnemonicParsing="false" text="Cancella" onAction="#cancella"/>
            </children>
        </HBox>

        <TextArea fx:id="txtArea" prefHeight="200.0" prefWidth="200.0" text="Inserisci le dimensioni dei due lati, quello lungo e quello corto, per vedere le info del rettangolo qui disegnato"/>
    </children>
</VBox>
